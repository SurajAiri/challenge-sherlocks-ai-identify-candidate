# Copy to .env and fill in as needed. `pnpm dev` (via `uv run uvicorn
# ... --env-file .env`) loads this automatically.

# --- LLM-backed identifiers (engine/identifiers/llm_name_role.py,
# engine/identifiers/llm_transcript_role.py) ---
# Any model string litellm understands, in "<provider>/<model>" form.
# Must support structured/JSON-schema-constrained output - check with
# `litellm.supports_response_schema(model=..., custom_llm_provider=...)`.
LLM_MODEL=fireworks_ai/accounts/fireworks/models/deepseek-v4-flash

# Provider credentials - set whichever your LLM_MODEL needs. For the
# default Fireworks model:
FIREWORKS_API_KEY=

# How long (seconds) to wait for a single LLM call before giving up.
# On timeout the identifier fails open (emits nothing this tick) - see
# engine/core/llm_client.py.
LLM_REQUEST_TIMEOUT_SECONDS=8
